{
  "manifest_version": 3,
  "name": "VPN Proxy - Free Servers",
  "version": "1.0.0",
  "description": "VPN proxy with free servers from online sources",
  "permissions": [
    "proxy",
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://cdn.jsdelivr.net/*",
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "VPN Proxy"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
